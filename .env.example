API_BASE_URL=http://localhost:8000
TRITON_URL=localhost:8001
REQUIRE_TRITON=0
COPY_BACKEND=mock
# Model ids below are course-guide placeholders; confirm via scripts/openai_smoke.py before relying on them.
COPY_MODEL_ID=gpt-5.4-mini
PRODUCT_ANALYSIS_BACKEND=mock
PRODUCT_ANALYSIS_MODEL_ID=gpt-5.4-mini
IMAGE_BACKEND=mock
IMAGE_MODEL_ID=gpt-image-1-mini
IMAGE_QUALITY=low
OPENAI_API_KEY=
# Optional cost guard overrides for paid smoke scripts. Leave blank to use
# built-in rates for explicitly supported models.
OPENAI_MAX_ESTIMATED_COST_USD=
OPENAI_COPY_INPUT_USD_PER_1M_TOKENS=
OPENAI_COPY_OUTPUT_USD_PER_1M_TOKENS=
OPENAI_IMAGE_USD_PER_1M_TOKENS=
FLUX2_MODEL_ID=black-forest-labs/FLUX.2-klein-4B
OUTPUT_DIR=outputs
GENERATION_LOG_PATH=logs/generations.jsonl

# Async generation job lane. Docker Compose uses rq + postgres; local tests default
# to inline + memory unless these values are set.
GENERATION_QUEUE_BACKEND=inline
GENERATION_QUEUE_NAME=ad-generation
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
GENERATION_JOB_RESULT_TTL_SECONDS=3600
GENERATION_JOB_FAILURE_TTL_SECONDS=86400
GENERATION_HISTORY_BACKEND=memory
GENERATION_HISTORY_DSN=

# Local pgvector lane. Stores curated marketing-guide vectors only.
MARKETING_CONTEXT_BACKEND=keyword
# Set MARKETING_CONTEXT_BACKEND=pgvector_hybrid to route retrieval through
# pgvector candidate generation plus request-keyword reranking.
PGVECTOR_IMAGE=pgvector/pgvector:pg16
PGVECTOR_HOST=localhost
PGVECTOR_PORT=5433
PGVECTOR_DB=dessert_ad_studio
PGVECTOR_USER=dessert
PGVECTOR_PASSWORD=dessert_dev_password
PGVECTOR_DSN=postgresql://dessert:dessert_dev_password@localhost:5433/dessert_ad_studio
